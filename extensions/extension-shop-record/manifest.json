{
  "manifest_version": 3,
  "theme_color": "#0d9488",
  "name": "Shop Record",
  "version": "0.4.2",
  "description": "Shop-side data recorder (logs + multi-page collectors + local writes).",
  "permissions": ["storage", "tabs"],
  "background": {
    "service_worker": "background.js"
  },
  "icons": {
    "16": "assets/icon-16.png",
    "32": "assets/icon-32.png",
    "48": "assets/icon-48.png",
    "128": "assets/icon-128.png"
  },
  "host_permissions": [
    "https://*.supabase.co/*",
    "https://qn.taobao.com/*",
    "https://trade.taobao.com/*",
    "https://rate.taobao.com/*",
    "https://ad.alimama.com/*",
    "https://one.alimama.com/*",
    "https://sycm.taobao.com/*",
    "https://oa1.ilanhe.com/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Shop Record",
    "default_icon": {
      "16": "assets/icon-16.png",
      "32": "assets/icon-32.png",
      "48": "assets/icon-48.png",
      "128": "assets/icon-128.png"
    }
  },
  "content_scripts": [
    {
      "matches": ["https://qn.taobao.com/*", "https://trade.taobao.com/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://rate.taobao.com/*"],
      "js": ["content-rate-refund-bridge.js"],
      "run_at": "document_start"
    },
    {
      "matches": ["https://rate.taobao.com/*"],
      "js": ["content-rate-refund-main.js"],
      "run_at": "document_start",
      "world": "MAIN"
    },
    {
      "matches": ["https://rate.taobao.com/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://ad.alimama.com/*"],
      "js": ["content-shop-metrics.js"],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://one.alimama.com/*"],
      "js": ["content-onebp-bridge.js"],
      "run_at": "document_start"
    },
    {
      "matches": ["https://one.alimama.com/*"],
      "js": ["content-onebp-main.js"],
      "run_at": "document_start",
      "world": "MAIN"
    },
    {
      "matches": ["https://sycm.taobao.com/*"],
      "js": ["content-shop-metrics.js"],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://oa1.ilanhe.com/*"],
      "js": ["content-report-submit-main.js"],
      "run_at": "document_idle",
      "world": "MAIN"
    },
    {
      "matches": ["https://oa1.ilanhe.com/*"],
      "js": ["content-report-submit.js"],
      "run_at": "document_idle"
    }
  ]
}
