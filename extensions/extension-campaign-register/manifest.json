{
  "manifest_version": 3,
  "theme_color": "#0d9488",
  "name": "Campaign Register",
  "version": "1.1.15",
  "description": "Capture campaign lists from one.alimama.com and maintain local register snapshots.",
  "permissions": ["storage", "tabs"],
  "background": {
    "service_worker": "background.js"
  },
  "icons": {
    "16": "assets/icon-16.png",
    "32": "assets/icon-32.png",
    "48": "assets/icon-48.png",
    "128": "assets/icon-128.png"
  },
  "host_permissions": ["https://one.alimama.com/*"],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Campaign Register",
    "default_icon": {
      "16": "assets/icon-16.png",
      "32": "assets/icon-32.png",
      "48": "assets/icon-48.png",
      "128": "assets/icon-128.png"
    }
  },
  "content_scripts": [
    {
      "matches": ["https://one.alimama.com/*"],
      "js": ["content.js"],
      "run_at": "document_start",
      "all_frames": true
    },
    {
      "matches": ["https://one.alimama.com/*"],
      "js": ["main.js"],
      "run_at": "document_start",
      "all_frames": true,
      "world": "MAIN"
    }
  ]
}
