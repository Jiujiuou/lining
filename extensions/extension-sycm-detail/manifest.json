{
  "manifest_version": 3,
  "name": "生意参谋详情数据",
  "version": "1.0.9",
  "description": "在生意参谋商品详情页采集加购/搜索等指标并同步至 Supabase",
  "permissions": ["storage"],
  "host_permissions": [
    "https://sycm.taobao.com/*",
    "https://*.supabase.co/*"
  ],
  "icons": {
    "32": "assets/favicon-32x32.png",
    "48": "assets/favicon-32x32.png"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "生意参谋详情数据",
    "default_icon": {
      "32": "assets/favicon-32x32.png"
    }
  },
  "web_accessible_resources": [
    {
      "resources": ["constants/config.js", "inject.js"],
      "matches": ["https://sycm.taobao.com/*"]
    }
  ],
  "content_scripts": [
    {
      "matches": ["https://sycm.taobao.com/*"],
      "js": [
        "constants/defaults.js",
        "constants/config.js",
        "constants/supabase.js",
        "utils/time.js",
        "utils/supabase.js",
        "utils/storage.js",
        "utils/logger.js",
        "content.js"
      ],
      "run_at": "document_start",
      "all_frames": true
    }
  ]
}
