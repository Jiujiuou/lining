{
  "manifest_version": 3,
  "theme_color": "#0d9488",
  "name": "订单用户数据导出",
  "version": "1.1.0",
  "description": "从千牛/淘宝已卖出订单导出订单号与买家昵称（可与「生意参谋详情数据」等扩展并存）",
  "permissions": ["scripting", "storage", "tabs"],
  "background": {
    "service_worker": "background.js"
  },
  "icons": {
    "16": "assets/icon-16.png",
    "32": "assets/icon-32.png",
    "48": "assets/icon-48.png",
    "128": "assets/icon-128.png"
  },
  "host_permissions": [
    "https://qn.taobao.com/*",
    "https://trade.taobao.com/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "订单用户数据导出",
    "default_icon": {
      "16": "assets/icon-16.png",
      "32": "assets/icon-32.png",
      "48": "assets/icon-48.png",
      "128": "assets/icon-128.png"
    }
  },
  "web_accessible_resources": [
    {
      "resources": ["order-userdata-main.js"],
      "matches": ["https://qn.taobao.com/*", "https://trade.taobao.com/*"]
    }
  ],
  "content_scripts": [
    {
      "matches": ["https://qn.taobao.com/*", "https://trade.taobao.com/*"],
      "js": ["order-userdata-cs.js"],
      "run_at": "document_start"
    }
  ]
}
