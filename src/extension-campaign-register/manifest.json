{
  "manifest_version": 3,
  "name": "万相台推广登记",
  "version": "1.0.0",
  "description": "万相台推广列表捕获与手动登记至 Supabase（与「数据获取」扩展可并行安装验证）",
  "permissions": ["storage", "tabs"],
  "host_permissions": [
    "https://one.alimama.com/*",
    "https://*.supabase.co/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "万相台推广登记"
  },
  "content_scripts": [
    {
      "matches": ["https://one.alimama.com/*"],
      "js": ["capture-findpage-cs.js"],
      "run_at": "document_start",
      "all_frames": true
    },
    {
      "matches": ["https://one.alimama.com/*"],
      "js": ["capture-findpage-main.js"],
      "run_at": "document_start",
      "all_frames": true,
      "world": "MAIN"
    }
  ]
}
